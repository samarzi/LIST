# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com

# База данных
DATABASE_URL=postgresql://user:password@localhost:5432/list_db

# Redis (опционально для MVP)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# Приложение
NODE_ENV=development
PORT=3000

# Mini App URL (фронтенд)
MINI_APP_URL=https://your-app.vercel.app

# Хранилище файлов (S3 / Cloudflare R2 / MinIO)
S3_BUCKET_NAME=list-uploads
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_REGION=auto
S3_ENDPOINT=https://your-r2-account.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://your-custom-domain.com
S3_FORCE_PATH_STYLE=true

# Мониторинг ошибок (Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
